generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Workspace ─────────────────────────────────────────────────────────────────

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  currency  String   @default("SAR")
  taxRate   Decimal  @default(15) @db.Decimal(5, 2)
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members            WorkspaceMember[]
  activityLogs       ActivityLog[]
  industries         Industry[]
  referrals          Referral[]
  companies          Company[]
  contacts           Contact[]
  services           Service[]
  deals              Deal[]
  projects           Project[]
  invoices           Invoice[]
  pipelines          Pipeline[]
  projectStatuses    ProjectStatus[]
  taskStatuses       TaskStatus[]
  customFields       CustomFieldDef[]
  whatsappConfig     WhatsAppConfig?
  whatsappTemplates  WhatsAppTemplate[]
  roles              Role[]
}

// ─── Team & Roles ──────────────────────────────────────────────────────────────

model WorkspaceMember {
  id          String       @id @default(cuid())
  workspaceId String
  userId      String       // Clerk user ID
  email       String
  name        String?
  type        MemberType   @default(MEMBER)
  roleId      String?
  joinedAt    DateTime     @default(now())

  workspace   Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  role        Role?        @relation(fields: [roleId], references: [id])
  assignedTasks Task[]     @relation("TaskAssignee")

  @@unique([workspaceId, userId])
}

enum MemberType {
  OWNER
  MEMBER
  FREELANCER
}

model Role {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  permissions Json     // { deals: "full", invoices: "view", ... }
  createdAt   DateTime @default(now())

  workspace   Workspace        @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  members     WorkspaceMember[]

  @@unique([workspaceId, name])
}

// ─── Freelancer Access ─────────────────────────────────────────────────────────

model ProjectCollaborator {
  id          String              @id @default(cuid())
  projectId   String
  memberId    String
  status      CollaboratorStatus  @default(PENDING)
  invitedAt   DateTime            @default(now())
  invitedVia  String?             // "whatsapp" | "email"

  project     Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

enum CollaboratorStatus {
  PENDING
  ACTIVE
  REVOKED
}

// ─── Companies & Contacts ──────────────────────────────────────────────────────

model Company {
  id             String    @id @default(cuid())
  workspaceId    String
  name           String
  nameAr         String?
  industry       String?
  referral       String?
  phone          String?
  whatsappNumber String?
  email          String?
  website        String?
  address        String?
  logo           String?
  notes          String?
  customFields   Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  workspace      Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  deals          Deal[]
  projects       Project[]
}

model Contact {
  id              String   @id @default(cuid())
  workspaceId     String
  companyId       String?
  firstName       String
  middleName      String?
  lastName        String
  nameAr          String?
  mobile          String
  email           String?
  role            String?
  country         String
  notes           String?
  customFields    Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  company         Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deals           Deal[]
  invoices        Invoice[]
  whatsappMessages WhatsAppMessage[]

  @@unique([workspaceId, mobile])
}

// ─── Services Catalog ──────────────────────────────────────────────────────────

model Service {
  id            String       @id @default(cuid())
  workspaceId   String
  name          String
  description   String?
  pricingType   PricingType  @default(FIXED)
  unitPrice     Decimal      @db.Decimal(12, 2)
  unit          String?      // "month", "piece", "hour", etc.
  taxable       Boolean      @default(true)
  active        Boolean      @default(true)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  workspace     Workspace    @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  dealItems     DealItem[]
  tasks         Task[]
}

enum PricingType {
  FIXED
  MONTHLY
  PER_UNIT
  HOURLY
}

// ─── Pipelines & Stages (Dynamic) ─────────────────────────────────────────────

model Pipeline {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())

  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  stages      PipelineStage[]
  deals       Deal[]
}

model PipelineStage {
  id          String    @id @default(cuid())
  pipelineId  String
  name        String
  order       Int
  color       String    @default("#3b82f6")
  type        StageType @default(OPEN)
  createdAt   DateTime  @default(now())

  pipeline    Pipeline  @relation(fields: [pipelineId], references: [id], onDelete: Cascade)
  deals       Deal[]

  @@unique([pipelineId, order])
}

enum StageType {
  OPEN
  WON
  LOST
}

// ─── Deals ─────────────────────────────────────────────────────────────────────

model Deal {
  id              String   @id @default(cuid())
  workspaceId     String
  pipelineId      String
  stageId         String
  companyId       String?
  contactId       String?
  title           String
  value           Decimal  @db.Decimal(12, 2)
  expectedCloseDate DateTime?
  lostReason      String?
  notes           String?
  customFields    Json?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  closedAt        DateTime?
  deletedAt       DateTime?

  workspace       Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  pipeline        Pipeline      @relation(fields: [pipelineId], references: [id])
  stage           PipelineStage @relation(fields: [stageId], references: [id])
  company         Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact         Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  items           DealItem[]
  project         Project?
}

model DealItem {
  id          String   @id @default(cuid())
  dealId      String
  serviceId   String
  quantity    Int      @default(1)
  unitPrice   Decimal  @db.Decimal(12, 2)
  description String?  // Override description for this deal

  deal        Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)
  service     Service  @relation(fields: [serviceId], references: [id])
}

// ─── Projects ──────────────────────────────────────────────────────────────────

model ProjectStatus {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  order       Int
  color       String   @default("#3b82f6")
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  projects    Project[]

  @@unique([workspaceId, order])
}

model Project {
  id            String    @id @default(cuid())
  workspaceId   String
  dealId        String?   @unique
  companyId     String?
  contactId     String?
  statusId      String?
  name          String
  description   String?
  startDate     DateTime?
  deadline      DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  workspace     Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  deal          Deal?                @relation(fields: [dealId], references: [id], onDelete: SetNull)
  company       Company?             @relation(fields: [companyId], references: [id], onDelete: SetNull)
  status        ProjectStatus?       @relation(fields: [statusId], references: [id])
  tasks         Task[]
  invoices      Invoice[]
  collaborators ProjectCollaborator[]
}

// ─── Tasks ─────────────────────────────────────────────────────────────────────

model TaskStatus {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  order       Int
  color       String   @default("#3b82f6")
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  tasks       Task[]

  @@unique([workspaceId, order])
}

model Task {
  id           String   @id @default(cuid())
  projectId    String
  serviceId    String?  // Links back to the service item (if billable)
  statusId     String?
  assigneeId   String?  // WorkspaceMember ID (team or freelancer)
  title        String
  description  String?
  billable     Boolean  @default(true)
  price        Decimal? @db.Decimal(12, 2)
  dueDate      DateTime?
  completedAt  DateTime?
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  project      Project          @relation(fields: [projectId], references: [id], onDelete: Cascade)
  service      Service?         @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  status       TaskStatus?      @relation(fields: [statusId], references: [id])
  assignee     WorkspaceMember? @relation("TaskAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
}

// ─── Invoices ──────────────────────────────────────────────────────────────────

model Invoice {
  id            String        @id @default(cuid())
  workspaceId   String
  projectId     String?
  contactId     String?
  number        String        // Auto-generated: INV-001, INV-002, etc.
  status        InvoiceStatus @default(DRAFT)
  subtotal      Decimal       @db.Decimal(12, 2)
  taxAmount     Decimal       @db.Decimal(12, 2)
  total         Decimal       @db.Decimal(12, 2)
  currency      String        @default("SAR")
  notes         String?
  dueDate       DateTime?
  sentAt        DateTime?
  acceptedAt    DateTime?
  rejectedAt    DateTime?
  paidAt        DateTime?
  rejectionNote String?
  publicToken   String        @unique @default(cuid()) // For public invoice link
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  project       Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  contact       Contact?      @relation(fields: [contactId], references: [id], onDelete: SetNull)
  items         InvoiceItem[]
}

enum InvoiceStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  PAID
  CANCELLED
}

model InvoiceItem {
  id          String  @id @default(cuid())
  invoiceId   String
  description String
  quantity    Int     @default(1)
  unitPrice   Decimal @db.Decimal(12, 2)
  total       Decimal @db.Decimal(12, 2)

  invoice     Invoice @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
}

// ─── WhatsApp ──────────────────────────────────────────────────────────────────

model WhatsAppConfig {
  id              String   @id @default(cuid())
  workspaceId     String   @unique
  phoneNumberId   String
  accessToken     String
  verifyToken     String
  businessName    String?
  connected       Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  workspace       Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}

model WhatsAppTemplate {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  event       String   // "invoice_sent", "invoice_reminder", "deal_update", etc.
  body        String   // Template with {{variables}}
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, event])
}

model WhatsAppMessage {
  id          String           @id @default(cuid())
  contactId   String
  direction   MessageDirection
  body        String
  templateId  String?
  status      MessageStatus    @default(PENDING)
  linkedType  String?          // "invoice", "deal", "project"
  linkedId    String?
  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  createdAt   DateTime         @default(now())

  contact     Contact          @relation(fields: [contactId], references: [id], onDelete: Cascade)
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum MessageStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

// ─── Activity Log ──────────────────────────────────────────────────────────────

model ActivityLog {
  id          String   @id @default(cuid())
  workspaceId String
  userId      String   // Clerk user ID
  userName    String?
  userImage   String?
  entityType  String   // "company", "contact", "deal", "project", "task", "invoice", "service"
  entityId    String
  entityName  String?  // Snapshot of the entity name at time of change
  action      String   // "created", "updated", "deleted", "moved", "sent", "accepted", "rejected", "paid"
  changes     Json?    // { field: { from: "old", to: "new" } }
  metadata    Json?    // Extra context (e.g. stage name for deal moves)
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, entityType, entityId])
  @@index([workspaceId, createdAt])
}

// ─── Industries (Dynamic) ──────────────────────────────────────────────────────

model Industry {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
}

model Referral {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  order       Int      @default(0)
  createdAt   DateTime @default(now())

  workspace   Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, name])
}

// ─── Custom Fields (Dynamic) ───────────────────────────────────────────────────

model CustomFieldDef {
  id          String          @id @default(cuid())
  workspaceId String
  entityType  CustomFieldEntity
  name        String
  label       String
  fieldType   CustomFieldType
  options     Json?           // For dropdown: ["Option A", "Option B"]
  required    Boolean         @default(false)
  order       Int             @default(0)
  createdAt   DateTime        @default(now())

  workspace   Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, entityType, name])
}

enum CustomFieldEntity {
  COMPANY
  CONTACT
  DEAL
}

enum CustomFieldType {
  TEXT
  NUMBER
  DATE
  DROPDOWN
  CHECKBOX
  URL
  PHONE
}
